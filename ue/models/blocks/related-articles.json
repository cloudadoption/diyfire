          "description": "A list of links to specific articles.",
          "condition": { "===": [{ "var": "classes" }, "links"] }
        },
        {
          "component": "text",
          "name": "keywords",
          "label": "Keywords",
          "description": "Comma-separated keywords to match articles (e.g. fire, tfsa, rrsp). Use 'random' for random articles.",
          "condition": { "===": [{ "var": "classes" }, "dynamic"] }
        },
        {
          "component": "text",
          "name": "excluded-keywords",
          "label": "Excluded Keywords",
          "description": "Comma-separated keywords to exclude (e.g. external)",
          "condition": { "===": [{ "var": "classes" }, "dynamic"] }
        }
      ]
    }
